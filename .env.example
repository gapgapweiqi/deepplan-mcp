# ─── DeepPlan Proxy Mode (Recommended) ───
# Generate an API key at your DeepPlan dashboard → API Keys page
DEEPPLAN_API_KEY=dpk_your-key-here
# DEEPPLAN_API_URL=https://deepplan.dev/api/mcp/council  # default, no need to change

# ─── Direct Mode (Fallback — used only if DEEPPLAN_API_KEY is not set) ───
# OpenRouter API Key — get yours at https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-your-key-here

# AI model for expert analysis (optional, defaults to minimax/minimax-m2.5)
# OPENROUTER_MODEL=minimax/minimax-m2.5

# Max characters for draft_plan input (optional, default 8000)
# DRAFT_PLAN_MAX_LENGTH=8000
